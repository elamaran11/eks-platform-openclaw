# eks-platform-openclaw — deployment parameters
#
# Copy to `.env` and fill in your values, then run `./scripts/install.sh`.
# install.sh sources this file (if present) and generates terraform/terraform.tfvars
# from it, so you configure the deployment in ONE place instead of hand-editing tfvars.
#
#   cp .env.example .env
#   # edit .env
#   ./scripts/install.sh
#
# .env is gitignored — never commit real account IDs, cert ARNs, or domains.
# If terraform/terraform.tfvars already exists, install.sh leaves it untouched
# (delete it first if you want .env to regenerate it).

# ---- Required (no defaults) ----

# Git repo ArgoCD watches for the app-of-apps root
GITOPS_REPO_URL="https://github.com/YOUR_ORG/eks-platform-openclaw"

# Route53 public hosted zone external-dns manages records in
ROUTE53_ZONE_ID="Z0123456789ABCDEFGHIJ"
ROUTE53_ZONE_NAME="example.com"

# ACM wildcard cert ARN for the domain
WILDCARD_CERT_ARN="arn:aws:acm:us-west-2:123456789012:certificate/your-cert-id"

# Public hostname for the finance-assistant UI
FINANCE_UI_HOST="finassist.example.com"

# ---- Optional (defaults shown) ----

REGION="us-west-2"
BEDROCK_REGION="us-west-2"
PROJECT_NAME="openclaw"
CLUSTER_VERSION="1.36"

# finance-ui image tag install.sh renders into the deployment (default: latest)
# FINANCE_UI_TAG="v0.9.7"

# Git branch/tag ArgoCD tracks for the app-of-apps root (default: HEAD).
# Set to a branch name to have ArgoCD deploy from that branch.
# GITOPS_TARGET_REVISION="main"

# Additional IAM role ARNs granted cluster-admin via EKS access entries.
# Comma-separated; install.sh expands this into a Terraform list.
# ADMIN_ROLE_ARNS="arn:aws:iam::123456789012:role/my-admin-role"

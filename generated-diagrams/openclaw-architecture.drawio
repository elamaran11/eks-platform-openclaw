        <mxCell id="packer-group" parent="1" style="rounded=1;arcSize=4;strokeColor=#FF4F00;fillColor=#FFF3E6;strokeDashArray=8 4;strokeWidth=2;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=11;fontStyle=1;fontColor=#B13400;" value="One-time: Packer AMI bake (scripts/install.sh)" vertex="1">
          <mxGeometry x="180" y="1000" width="240" height="110" as="geometry" />

        <mxCell id="packer-dtl" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=0;fillColor=none;strokeColor=none;fontColor=#333333;" value="packer build&#xa;  AL2023 + Kata 3.27&#xa;  + QEMU + CH&#xa;→ AMI → tfvars" vertex="1">
          <mxGeometry x="260" y="1020" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- ============ Browser (left) ============ -->
        <mxCell id="user" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;fillColor=#232F3E;labelBackgroundColor=#ffffff;align=center;html=1;fontSize=12;fontStyle=1;shape=mxgraph.aws4.user;" value="" vertex="1">
          <mxGeometry x="196" y="500" width="56" height="68" as="geometry" />

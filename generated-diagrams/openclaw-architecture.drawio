        <mxCell id="user-lbl" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;" value="Browser&#xa;@amazon.com" vertex="1">
          <mxGeometry x="170" y="570" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- ============ Flow legend (bottom-left, numbered) ============ -->
        <mxCell id="legend" parent="1" style="rounded=1;arcSize=4;strokeColor=#888888;fillColor=#FFFFE0;fontSize=11;fontStyle=0;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;html=1;fontColor=#333333;" value="&lt;b&gt;Flow&lt;/b&gt;&#xa;&#xa;&lt;b&gt;①&lt;/b&gt; Browser → ALB → finance-ui&#xa;&lt;b&gt;②&lt;/b&gt; UI calls Cognito directly (no ALB OIDC)&#xa;&lt;b&gt;③&lt;/b&gt; UI fires /api/warmup (after sign-in)&#xa;&lt;b&gt;④&lt;/b&gt; Router creates PVC + Sandbox (withRetry)&#xa;&lt;b&gt;⑤&lt;/b&gt; Karpenter provisions Kata node from baked AMI&#xa;&lt;b&gt;⑥&lt;/b&gt; User types — SSE /api/chat to router&#xa;&lt;b&gt;⑦&lt;/b&gt; Adapter → openclaw loopback :18789&#xa;&lt;b&gt;⑧&lt;/b&gt; openclaw → LiteLLM → Bedrock (Opus / Haiku)&#xa;&lt;b&gt;⑨&lt;/b&gt; Tokens stream back with timestamp + latency&#xa;&lt;b&gt;⑩&lt;/b&gt; Idle &gt;30m → reaper deletes Sandbox (EFS kept)" vertex="1">
          <mxGeometry x="60" y="640" width="310" height="320" as="geometry" />
        </mxCell>

        <!-- ============ Edges ============ -->
        <!-- ① user → ALB -->
        <mxCell id="e1" parent="1" source="user" target="alb-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#232F3E;strokeWidth=2;fontSize=11;fontStyle=1;endArrow=classic;" value="①">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ALB → finance-ui -->
        <mxCell id="e-alb-ui" parent="1" source="alb-ic" target="ui-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#232F3E;strokeWidth=2;endArrow=classic;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ② UI → Cognito -->
        <mxCell id="e2" parent="1" source="ui-ic" target="cognito-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;strokeWidth=2;dashed=1;fontSize=11;fontStyle=1;endArrow=classic;" value="② /api/auth/*">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Cognito ↔ Lambda -->
        <mxCell id="e-cog-lambda" parent="1" source="cognito-ic" target="lambda-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F7981F;strokeWidth=1.5;dashed=1;endArrow=classic;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ③ UI → router -->
        <mxCell id="e3" parent="1" source="ui-ic" target="router-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2875E2;strokeWidth=2.5;fontSize=11;fontStyle=1;endArrow=classic;" value="③ /api/warmup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ④ router → kata-node (k8s create) -->
        <mxCell id="e4" parent="1" source="router-ic" target="kata-node" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FF6B35;strokeWidth=2.5;fontSize=11;fontStyle=1;endArrow=classic;" value="④ ensure Sandbox+PVC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ⑤ nodepools card → kata-node (provisions) -->
        <mxCell id="e5" parent="1" source="np-card" target="kata-node" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FF6B35;strokeWidth=1.5;dashed=1;fontSize=11;fontStyle=2;fontColor=#B13400;endArrow=classic;" value="⑤ provisions node">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ⑥ UI → router (chat) -->
        <mxCell id="e6" parent="1" source="router-ic" target="openclaw-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2875E2;strokeWidth=2.5;fontSize=11;fontStyle=1;endArrow=classic;" value="⑥ /api/chat (SSE)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ⑦ openclaw → adapter internal (loopback) — small within VM: express as inline vertical label instead of edge to avoid clutter -->

        <!-- ⑧ openclaw → litellm (right to left) -->
        <mxCell id="e8" parent="1" source="openclaw-ic" target="litellm-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2875E2;strokeWidth=2;fontSize=11;fontStyle=1;endArrow=classic;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" value="⑧ OpenAI compat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- litellm → guardrail -->
        <mxCell id="e-litellm-guard" parent="1" source="litellm-ic" target="guardrail-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#01A88D;strokeWidth=2;fontSize=11;fontStyle=1;endArrow=classic;" value="Bedrock Converse">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- guardrail → claude -->
        <mxCell id="e-guard-claude" parent="1" source="guardrail-ic" target="claude-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#01A88D;strokeWidth=2;endArrow=classic;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- PVC → EFS -->
        <mxCell id="e-pvc-efs" parent="1" source="ws-ic" target="efs-ic" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#277116;strokeWidth=2;fontSize=11;fontStyle=1;endArrow=classic;" value="NFS 2049">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ⑩ reaper ⇢ kata-node -->
        <mxCell id="e10" parent="1" source="reaper-ic" target="kata-node" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#808080;strokeWidth=1.5;dashed=1;fontSize=11;fontStyle=2;fontColor=#555555;endArrow=classic;" value="⑩ deletes idle Sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- packer → nodepools -->
        <mxCell id="e-packer-np" parent="1" source="packer-ic" target="np-card" edge="1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FF4F00;strokeWidth=1.5;dashed=1;fontSize=10;fontStyle=2;fontColor=#B13400;endArrow=classic;" value="baked AMI id → amiSelector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>

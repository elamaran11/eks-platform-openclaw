        <mxCell id="packer-ic" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#FF4F00;strokeColor=#ffffff;labelBackgroundColor=#ffffff;align=center;html=1;fontSize=11;fontStyle=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2_ami;" value="" vertex="1">
          <mxGeometry x="198" y="1020" width="50" height="50" as="geometry" />
